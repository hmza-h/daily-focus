<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Document</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
</head>

<body>
  <div class="app-card">
    <div id="header">
      <h1>DEVELOPER TASK COMMAND CENTER</h1>
    </div>

    <form class="task" action="/submit-task" method="POST">
      <input type="text" placeholder="Enter a new task..." name="newTask" required />
      <button type="submit" id="taskButton">Add Task</button>
    </form>
    <ul>
      <% tasks.forEach((task, index)=> { %>
        <% if (task && task.text) { %>
          <li class="priority-<%= task.priority || 'none' %>">

            <span class="task-text">
              <%= task.text %>
            </span>

            <div class="task-actions">
              <div class="priority-dropdown">
                <% const priorityLabel = task.priority === 'high' ? '🔴 High' : task.priority === 'medium' ? '🟡 Medium' : task.priority === 'low' ? '🔵 Low' : 'Priority'; %>
                <button class="priority-trigger" type="button"><%= priorityLabel %></button>
                <div class="dropdown-content">
                  <form action="/update-priority/<%= index %>?level=high" method="POST">
                    <button type="submit" class="btn-high">🔴 High</button>
                  </form>
                  <form action="/update-priority/<%= index %>?level=medium" method="POST">
                    <button type="submit" class="btn-medium">🟡 Medium</button>
                  </form>
                  <form action="/update-priority/<%= index %>?level=low" method="POST">
                    <button type="submit" class="btn-low">🔵 Low</button>
                  </form>
                </div>
              </div>

              <form action="/delete/<%= index %>" method="POST">
                <button type="submit" class="delete-btn">Delete</button>
              </form>
            </div>

          </li>
          <% } %>
            <% }) %>
    </ul>

  </div>

</body>

</html>